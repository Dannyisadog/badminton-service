# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE Bot (Messaging API Channel)
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# LINE LIFF (LINE Login Channel)
# NEXT_PUBLIC_ prefix exposes to browser
NEXT_PUBLIC_LIFF_ID=1234567890-AbcDefGh
# Channel ID is the part before the dash in LIFF_ID
LIFF_CHANNEL_ID=1234567890

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Vercel Cron protection secret (set in Vercel dashboard → Settings → Cron)
CRON_SECRET=your-cron-secret
